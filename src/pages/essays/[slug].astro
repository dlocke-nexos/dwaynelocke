---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorPhoto from '../../components/AuthorPhoto.astro';
import FollowStrip from '../../components/FollowStrip.astro';
import { t } from '../../i18n';
import { essayTitle, essayDescription, essayEmphasis } from '../../i18n/essay-meta';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) => !data.draft);
  return essays.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const copy = t('en');
const dateStr = entry.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const title = essayTitle(entry.data, 'en');
const emphasis = essayEmphasis(entry.data, 'en');
const titleParts = emphasis ? title.split(emphasis) : [title];
---
<BaseLayout title={`${title} — Dwayne Locke`} description={essayDescription(entry.data, 'en')} locale="en">
  <div class="wrap">
    <header class="mast mast--author">
      <AuthorPhoto />
      <div class="eyebrow">{copy.index.eyebrow}</div>
      <h1>
        {titleParts[0]}{emphasis && <em>{emphasis}</em>}{titleParts[1] ?? ''}
      </h1>
      <p class="standfirst">{essayDescription(entry.data, 'en')}</p>
      <p class="byline">{copy.essay.byline} · {dateStr}</p>
    </header>
  </div>

  <article class="wrap essay">
    <Content />
    <a href="/#essays" class="backlink">{copy.essay.backLink}</a>
  </article>

  <FollowStrip locale="en" />
</BaseLayout>
