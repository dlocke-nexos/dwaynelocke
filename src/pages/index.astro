---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FollowStrip from '../components/FollowStrip.astro';
import AuthorPhoto from '../components/AuthorPhoto.astro';
import { t, essayPath } from '../i18n';
import { essayTitle, essayDescription } from '../i18n/essay-meta';

const copy = t('en');

const all = (await getCollection('essays')).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);
const anchor = all.find((e) => !e.data.draft);
if (!anchor) throw new Error('No published anchor essay found in src/content/essays/.');
const { Content } = await anchor.render();

const titleParts = copy.index.title.split(copy.index.titleEmphasis);
---
<BaseLayout title={copy.meta.indexTitle} locale="en">
  <div id="top" class="wrap">
    <header class="mast mast--author">
      <AuthorPhoto />
      <div class="eyebrow">{copy.index.eyebrow}</div>
      <h1>
        {titleParts[0]}<em>{copy.index.titleEmphasis}</em>{titleParts[1] ?? ''}
      </h1>
      <p class="standfirst">{copy.index.standfirst}</p>
      <p class="byline">{copy.index.byline}</p>
    </header>
  </div>

  <article class="wrap essay">
    <Content />
  </article>

  <FollowStrip locale="en" />

  <section class="more wide" id="essays">
    <div class="sec-eyebrow">{copy.index.writing}</div>
    <div class="plist">
      {all.map((e) =>
        e.data.draft ? (
          <a class="pitem soon">
            <div class="pt">{essayTitle(e.data, 'en')}</div>
            <div class="pd">{essayDescription(e.data, 'en')}</div>
          </a>
        ) : (
          <a class="pitem live" href={essayPath(e.slug, 'en', e.slug === anchor.slug)}>
            <div class="pt">{essayTitle(e.data, 'en')}</div>
            <div class="pd">{essayDescription(e.data, 'en')}</div>
          </a>
        )
      )}
    </div>
  </section>
</BaseLayout>
