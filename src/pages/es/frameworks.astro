---
import HomeLayout from '../../layouts/HomeLayout.astro';
import MaturityFramework from '../../components/MaturityFramework.astro';
import { t } from '../../i18n';

const copy = t('es');
---
<HomeLayout
  title={copy.meta.frameworksTitle}
  description={copy.meta.frameworksDescription}
  locale="es"
>
  <section class="pub-framework-page wide">
    <header class="pub-framework-page-head">
      <p class="pub-framework-page-eyebrow">{copy.frameworks.eyebrow}</p>
      <h1>{copy.frameworks.title}</h1>
      <p class="pub-framework-page-lede">{copy.frameworks.lede}</p>
    </header>
    <MaturityFramework locale="es" />
  </section>
</HomeLayout>
