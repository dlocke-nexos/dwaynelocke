---
import HomeLayout from '../layouts/HomeLayout.astro';
import MaturityFramework from '../components/MaturityFramework.astro';
---
<HomeLayout
  title="Capability Framework — Dwayne Locke"
  description="Structure and evolution — two independent dimensions for how capability digitizes inside what you already have."
>
  <section class="pub-framework-page wide">
    <header class="pub-framework-page-head">
      <p class="pub-framework-page-eyebrow">Frameworks</p>
      <h1>Capability Framework</h1>
      <p class="pub-framework-page-lede">
        Two dimensions &mdash; structure and evolution &mdash; not a ladder to climb.
        Explore how each function operates at each stage of maturity.
      </p>
    </header>
    <MaturityFramework />
  </section>
</HomeLayout>
