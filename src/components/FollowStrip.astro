---
import { t, type Locale, homePath } from '../i18n';

interface Props {
  locale?: Locale;
}
const locale = Astro.props.locale ?? 'en';
const copy = t(locale);
const home = homePath(locale);
---
<section class="follow-strip wide">
  <div class="follow-strip-inner">
    <p>{copy.followStrip.body}</p>
    <a href={`${home}#field-notes`} class="btn ghost">{copy.followStrip.cta}</a>
  </div>
</section>
