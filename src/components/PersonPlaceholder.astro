---
interface Props {
  size?: 'thumb' | 'featured';
  label?: string;
}
const { size = 'thumb', label = 'Author photo placeholder' } = Astro.props;
---
<div class={`person-placeholder person-placeholder--${size}`} role="img" aria-label={label}>
  <svg viewBox="0 0 120 120" fill="none" aria-hidden="true">
    <circle cx="60" cy="60" r="58" fill="var(--paper-2)" stroke="var(--line)" stroke-width="1" />
    <circle cx="60" cy="46" r="18" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="1" />
    <path
      d="M28 98c4-18 18-28 32-28s28 10 32 28"
      fill="var(--accent-bg)"
      stroke="var(--accent-soft)"
      stroke-width="1"
      stroke-linecap="round"
    />
  </svg>
</div>
