---
// Teaser preview — partial framework grid, motion kept inside the frame.
---
<div class="fw-teaser-visual" aria-hidden="true">
  <svg viewBox="0 0 360 260" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect class="fw-teaser-tab fw-teaser-tab--1" x="32" y="28" width="72" height="28" rx="8" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.5" />
    <rect class="fw-teaser-tab fw-teaser-tab--2" x="116" y="28" width="72" height="28" rx="8" fill="var(--paper)" stroke="var(--line)" stroke-width="0.5" />
    <rect class="fw-teaser-tab fw-teaser-tab--3" x="200" y="28" width="128" height="28" rx="8" fill="var(--paper)" stroke="var(--line)" stroke-width="0.5" opacity="0.7" />
    <rect class="fw-teaser-row fw-teaser-row--1" x="32" y="72" width="296" height="36" rx="8" fill="var(--paper)" stroke="var(--line)" stroke-width="0.5" />
    <rect class="fw-teaser-row fw-teaser-row--2" x="32" y="116" width="296" height="36" rx="8" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
    <rect class="fw-teaser-row fw-teaser-row--3" x="32" y="160" width="296" height="36" rx="8" fill="var(--paper)" stroke="var(--line)" stroke-width="0.5" />
    <rect class="fw-teaser-pill fw-teaser-pill--1" x="32" y="204" width="64" height="24" rx="6" fill="var(--accent)" opacity="0.75" />
    <rect class="fw-teaser-pill fw-teaser-pill--2" x="104" y="204" width="64" height="24" rx="6" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.5" />
    <rect class="fw-teaser-pill fw-teaser-pill--3" x="176" y="204" width="64" height="24" rx="6" fill="var(--paper)" stroke="var(--line)" stroke-width="0.5" />
    <rect class="fw-teaser-pill fw-teaser-pill--4" x="248" y="204" width="80" height="24" rx="6" fill="var(--paper)" stroke="var(--line)" stroke-width="0.5" opacity="0.55" />
    <path class="fw-teaser-gridlines" d="M48 86 H328 M48 130 H328 M48 174 H328" stroke="var(--line)" stroke-width="0.5" stroke-dasharray="4 6" />
    <rect class="fw-teaser-cell" x="156" y="120" width="48" height="28" rx="6" fill="var(--accent)" opacity="0" />
    <path class="fw-teaser-check" d="M284 36 L290 42 L302 28" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5" />
  </svg>
</div>
