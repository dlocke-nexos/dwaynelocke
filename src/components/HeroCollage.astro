---
// Editorial collage: overlapping panels showing the evolution of organizational work.
---
<div class="hero-collage" aria-hidden="true">
  <div class="hc-panel hc-panel--people">
    <div class="hc-label">People</div>
    <svg viewBox="0 0 160 120" fill="none">
      <circle cx="80" cy="28" r="14" stroke="var(--accent)" stroke-width="1.5" fill="var(--accent-bg)" />
      <circle cx="40" cy="58" r="11" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <circle cx="80" cy="58" r="11" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <circle cx="120" cy="58" r="11" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <circle cx="55" cy="88" r="9" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <circle cx="105" cy="88" r="9" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <line x1="80" y1="42" x2="40" y2="47" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="80" y1="42" x2="80" y2="47" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="80" y1="42" x2="120" y2="47" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="40" y1="69" x2="55" y2="79" stroke="var(--line)" stroke-width="1" />
      <line x1="80" y1="69" x2="55" y2="79" stroke="var(--line)" stroke-width="1" />
      <line x1="80" y1="69" x2="105" y2="79" stroke="var(--line)" stroke-width="1" />
      <line x1="120" y1="69" x2="105" y2="79" stroke="var(--line)" stroke-width="1" />
    </svg>
  </div>

  <div class="hc-panel hc-panel--software">
    <div class="hc-label">Software</div>
    <svg viewBox="0 0 160 120" fill="none">
      <rect x="18" y="16" width="124" height="88" rx="8" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <rect x="28" y="26" width="48" height="6" rx="2" fill="var(--accent-bg)" />
      <rect x="28" y="40" width="104" height="4" rx="1" fill="var(--line)" />
      <rect x="28" y="50" width="88" height="4" rx="1" fill="var(--line)" />
      <rect x="28" y="60" width="96" height="4" rx="1" fill="var(--line)" />
      <rect x="28" y="74" width="36" height="22" rx="4" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.5" />
      <rect x="70" y="74" width="36" height="22" rx="4" fill="var(--paper-2)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="112" y="74" width="20" height="22" rx="4" fill="var(--good)" opacity="0.25" />
    </svg>
  </div>

  <div class="hc-panel hc-panel--automation">
    <div class="hc-label">Automation</div>
    <svg viewBox="0 0 160 120" fill="none">
      <circle cx="40" cy="60" r="18" stroke="var(--accent)" stroke-width="1.5" fill="var(--accent-bg)" />
      <circle cx="40" cy="60" r="6" fill="var(--accent)" />
      <rect x="72" y="48" width="28" height="24" rx="6" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <rect x="116" y="48" width="28" height="24" rx="6" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <path d="M58 60 H72" stroke="var(--accent-soft)" stroke-width="1.5" marker-end="url(#hc-arrow)" />
      <path d="M100 60 H116" stroke="var(--accent-soft)" stroke-width="1.5" marker-end="url(#hc-arrow)" />
      <path class="hc-dash" d="M40 78 Q40 98 80 98 Q120 98 120 78" stroke="var(--line)" stroke-width="1" fill="none" stroke-dasharray="4 3" />
      <defs>
        <marker id="hc-arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
          <path d="M0,0 L6,3 L0,6" fill="var(--accent-soft)" />
        </marker>
      </defs>
    </svg>
  </div>

  <div class="hc-panel hc-panel--agents">
    <div class="hc-label">AI Agents</div>
    <svg viewBox="0 0 160 120" fill="none">
      <circle cx="80" cy="44" r="12" stroke="var(--accent)" stroke-width="1.5" fill="var(--accent-bg)" />
      <circle cx="44" cy="72" r="10" stroke="var(--accent-soft)" stroke-width="1" fill="var(--card)" />
      <circle cx="80" cy="82" r="10" stroke="var(--accent-soft)" stroke-width="1" fill="var(--card)" />
      <circle cx="116" cy="72" r="10" stroke="var(--accent-soft)" stroke-width="1" fill="var(--card)" />
      <circle cx="128" cy="40" r="7" stroke="var(--good)" stroke-width="1" fill="var(--card)" />
      <line x1="80" y1="56" x2="44" y2="62" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="80" y1="56" x2="80" y2="72" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="80" y1="56" x2="116" y2="62" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="116" y1="62" x2="128" y2="47" stroke="var(--line)" stroke-width="1" />
      <circle class="hc-glint" cx="24" cy="36" r="4" fill="var(--accent)" opacity="0.5" />
      <circle class="hc-glint hc-glint--delay" cx="140" cy="90" r="3" fill="var(--accent-soft)" />
    </svg>
  </div>

  <div class="hc-panel hc-panel--flow">
    <svg viewBox="0 0 120 80" fill="none">
      <rect x="8" y="12" width="28" height="18" rx="4" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.5" />
      <rect x="46" y="12" width="28" height="18" rx="4" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="84" y="12" width="28" height="18" rx="4" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="8" y="50" width="28" height="18" rx="4" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="46" y="50" width="28" height="18" rx="4" fill="var(--good)" opacity="0.2" stroke="var(--good)" stroke-width="0.5" />
      <path d="M36 21 H46 M74 21 H84 M22 30 V50 M60 30 V50 M98 30 V50" stroke="var(--accent-soft)" stroke-width="1" />
    </svg>
  </div>

  <div class="hc-panel hc-panel--memory">
    <svg viewBox="0 0 100 80" fill="none">
      <rect x="10" y="8" width="80" height="64" rx="6" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
      <line x1="20" y1="22" x2="70" y2="22" stroke="var(--accent)" stroke-width="1.5" />
      <line x1="20" y1="34" x2="60" y2="34" stroke="var(--line)" stroke-width="1" />
      <line x1="20" y1="44" x2="65" y2="44" stroke="var(--line)" stroke-width="1" />
      <line x1="20" y1="54" x2="50" y2="54" stroke="var(--line)" stroke-width="1" />
      <circle cx="78" cy="58" r="8" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
    </svg>
  </div>

  <div class="hc-accent hc-accent--1"></div>
  <div class="hc-accent hc-accent--2"></div>
</div>
