---
import { getLocale, switchLocalePath, t } from '../i18n';

interface Props {
  pathname?: string;
}
const pathname = Astro.props.pathname ?? Astro.url.pathname;
const locale = getLocale(pathname);
const copy = t(locale);
const enHref = switchLocalePath(pathname, 'en');
const esHref = switchLocalePath(pathname, 'es');
---
<div class="nav-lang" role="navigation" aria-label={copy.lang.label}>
  <a
    href={enHref}
    class={locale === 'en' ? 'active' : undefined}
    hreflang="en"
    lang="en"
    aria-current={locale === 'en' ? 'true' : undefined}
  >EN</a>
  <span class="nav-lang-sep" aria-hidden="true">·</span>
  <a
    href={esHref}
    class={locale === 'es' ? 'active' : undefined}
    hreflang="es"
    lang="es"
    aria-current={locale === 'es' ? 'true' : undefined}
  >ES</a>
</div>
