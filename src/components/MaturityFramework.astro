---
import { t, type Locale } from '../i18n';
import { getFrameworkData } from './framework-data';

interface Props {
  locale?: Locale;
}
const locale = Astro.props.locale ?? 'en';
const ui = t(locale).frameworkTool;
const { structureLayers, functions, evolutionStages, intersections } = getFrameworkData(locale);

const defaultFn = functions.find((f) => f.id === 'sales') ?? functions[0];
const defaultStage = evolutionStages.find((s) => s.id === 'human') ?? evolutionStages[0];
const defaultCell = intersections[defaultFn.id]?.[defaultStage.id];
const defaultKicker = `${ui.kickerIntersection} · ${defaultFn.label} × ${defaultStage.title}`;
const defaultTitle = defaultCell?.headline ?? '';
const frameworkPayload = JSON.stringify({ functions, evolutionStages, intersections, ui }).replace(
  /</g,
  '\\u003c'
);
---

<div class="fw-model">
  <div class="fw-thesis">
    <p class="fw-thesis-lead">{ui.thesisLead}</p>
    <p class="fw-thesis-body">
      <strong>{ui.structureWord}</strong>{ui.structureDesc}
      <strong>{ui.evolutionWord}</strong>{ui.evolutionDesc}
      {ui.thesisHoverFn}
      {ui.thesisHoverCell}<em>{ui.thesisIntersection}</em>{ui.thesisHoverEnd}
    </p>
  </div>

  <div class="fw-tabs" role="tablist" aria-label={ui.tabsAria}>
    <button type="button" class="fw-tab active" data-tab="structure" role="tab" aria-selected="true" id="fw-tab-structure">
      <span class="fw-tab-axis">{ui.dim1}</span>
      <span class="fw-tab-title">{ui.structureTab}</span>
      <span class="fw-tab-sub">{ui.structureTabSub}</span>
    </button>
    <button type="button" class="fw-tab" data-tab="evolution" role="tab" aria-selected="false" id="fw-tab-evolution">
      <span class="fw-tab-axis">{ui.dim2}</span>
      <span class="fw-tab-title">{ui.evolutionTab}</span>
      <span class="fw-tab-sub">{ui.evolutionTabSub}</span>
    </button>
  </div>

  <section class="fw-panel fw-panel--structure active" id="fw-panel-structure" role="tabpanel" aria-labelledby="fw-tab-structure">
    <div class="fw-structure-meta">
      <p class="fw-structure-rise"><span aria-hidden="true">&uarr;</span> {ui.structureRise}</p>
      <p class="fw-structure-stable">{ui.structureStable}</p>
    </div>
    <div class="fw-structure">
      <div class="fw-spine" aria-label={ui.spineAria}>
        <span class="fw-spine-label">{ui.spineLabel}</span>
        <span class="fw-spine-sub">{ui.spineSub}</span>
      </div>
      <div class="fw-stack">
        {structureLayers.map((layer) => (
          <button
            type="button"
            class={`fw-stack-layer fw-stack-layer--${layer.id}`}
            data-kind="structure"
            data-id={layer.id}
            data-title={layer.title}
            data-body={layer.body}
          >
            {layer.split ? (
              <div class="fw-split">
                <div class="fw-split-half">
                  <strong>{layer.left!.label}</strong>
                  <span>{layer.left!.sub}</span>
                </div>
                <div class="fw-split-half">
                  <strong>{layer.right!.label}</strong>
                  <span>{layer.right!.sub}</span>
                </div>
              </div>
            ) : (
              <>
                <strong>{layer.title}</strong>
                <span class="fw-stack-sub">{layer.sub}</span>
              </>
            )}
          </button>
        ))}
        <div class="fw-stack-layer fw-stack-layer--functions" id="fw-functions-layer">
          <div class="fw-functions-row">
            <span class="fw-functions-label">{ui.functionsLabel}</span>
            <div class="fw-pills" role="group" aria-label={ui.functionsAria}>
              {functions.map((fn, i) => (
                <button
                  type="button"
                  class={`fw-pill fw-pill--fn${i === 1 ? ' active' : ''}`}
                  data-kind="function"
                  data-id={fn.id}
                >
                  {fn.label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="fw-panel fw-panel--evolution" id="fw-panel-evolution" role="tabpanel" aria-labelledby="fw-tab-evolution" hidden>
    <div class="fw-evolution-intro">
      <p>
        {ui.evolutionIntroBefore}<em>{ui.evolutionIntroInfo}</em>{ui.evolutionIntroMid}<em>{ui.evolutionIntroCap}</em>{ui.evolutionIntroAfter}
      </p>
    </div>
    <p class="fw-capability-heading">{ui.capabilityHeading}</p>
    <div class="fw-timeline" role="tablist" aria-label={ui.timelineAria}>
      {evolutionStages.map((stage, i) => [
        i > 0 ? <div class="fw-timeline-arrow" aria-hidden="true">&rarr;</div> : null,
        <button
          type="button"
          class={`fw-stage fw-stage--${stage.id} fw-stage--pick${i === 0 ? ' active' : ''}`}
          data-kind="stage"
          data-id={stage.id}
          role="tab"
        >
          <span class="fw-stage-num">{ui.stageLabel} {stage.num}</span>
          <strong>{stage.title}</strong>
          <span class="fw-stage-sub">{stage.sub}</span>
          <span class="fw-stage-cap">{stage.capability}</span>
        </button>,
      ])}
    </div>
  </section>

  <section class="fw-explorer" aria-label={ui.explorerAria}>
    <p class="fw-explorer-hint">
      {ui.explorerHintBefore}<strong>{ui.explorerHintMiddle}</strong>{ui.explorerHintAfter}
    </p>
    <div class="fw-explorer-rows">
      <div class="fw-explorer-row">
        <span class="fw-explorer-label">{ui.functionLabel}</span>
        <div class="fw-pills fw-pills--explorer" role="group" aria-label={ui.functionSelectAria}>
          {functions.map((fn, i) => (
            <button type="button" class={`fw-pill fw-pill--fn${i === 1 ? ' active' : ''}`} data-kind="function" data-id={fn.id}>
              {fn.label}
            </button>
          ))}
        </div>
      </div>
      <div class="fw-explorer-row">
        <span class="fw-explorer-label">{ui.stageSelectLabel}</span>
        <div class="fw-pills fw-pills--explorer" role="group" aria-label={ui.stageSelectAria}>
          {evolutionStages.map((stage, i) => (
            <button type="button" class={`fw-pill fw-pill--stage${i === 0 ? ' active' : ''}`} data-kind="stage" data-id={stage.id}>
              {stage.num}. {stage.capability}
            </button>
          ))}
        </div>
      </div>
    </div>

    <div class="fw-matrix-wrap">
      <p class="fw-matrix-label">{ui.matrixLabel}</p>
      <div class="fw-matrix" role="grid" aria-label={ui.matrixAria}>
        <div class="fw-matrix-head" role="row">
          <div class="fw-matrix-corner" role="columnheader"></div>
          {evolutionStages.map((stage) => (
            <div class="fw-matrix-col-head" role="columnheader">{stage.capability}</div>
          ))}
        </div>
        {functions.map((fn) => (
          <div class="fw-matrix-row" role="row">
            <div class="fw-matrix-row-label" role="rowheader">{fn.label}</div>
            {evolutionStages.map((stage) => (
              <button
                type="button"
                class="fw-matrix-cell"
                role="gridcell"
                data-kind="cell"
                data-fn={fn.id}
                data-stage={stage.id}
                aria-label={`${fn.label} ${ui.cellAriaAt} ${stage.title}`}
              />
            ))}
          </div>
        ))}
      </div>
    </div>

    <div class="fw-panel-detail fw-panel-detail--explore" id="fw-explore-detail" role="region" aria-live="polite">
      <div class="fw-detail-kicker" id="fw-detail-kicker">{defaultKicker}</div>
      <h3 class="fw-detail-title" id="fw-detail-title">{defaultTitle}</h3>
      <div class="fw-detail-content" id="fw-detail-content">
        {defaultCell?.operations?.length ? (
          <div class="fw-detail-block">
            <h4>{ui.howWorkRuns}</h4>
            <ul>
              {defaultCell.operations.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ) : null}
        {defaultCell?.metrics?.length ? (
          <div class="fw-detail-block">
            <h4>{ui.metricsToWatch}</h4>
            <ul>
              {defaultCell.metrics.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ) : null}
      </div>
    </div>
  </section>
</div>

<script id="fw-framework-data" type="application/json" set:html={frameworkPayload} />

<script>
  const dataEl = document.getElementById('fw-framework-data');
  if (!dataEl?.textContent) throw new Error('Framework data missing');
  const { functions, evolutionStages, intersections, ui } = JSON.parse(dataEl.textContent);

  const state = {
    fn: 'sales',
    stage: 'human',
    mode: 'intersection',
    structureTitle: '',
    structureBody: '',
  };

  const fnMap = Object.fromEntries(functions.map((f) => [f.id, f]));
  const stageMap = Object.fromEntries(evolutionStages.map((s) => [s.id, s]));

  function setActive(kind, id, fnId, stageId) {
    document.querySelectorAll(`[data-kind="${kind}"]`).forEach((el) => {
      if (kind === 'cell') return;
      const match =
        kind === 'function'
          ? el.dataset.id === id
          : kind === 'stage'
            ? el.dataset.id === id
            : el.dataset.id === id;
      el.classList.toggle('active', match);
    });
    if (fnId) {
      document.querySelectorAll('[data-kind="function"]').forEach((el) => {
        el.classList.toggle('active', el.dataset.id === fnId);
      });
    }
    if (stageId) {
      document.querySelectorAll('[data-kind="stage"]').forEach((el) => {
        el.classList.toggle('active', el.dataset.id === stageId);
      });
    }
    document.querySelectorAll('[data-kind="cell"]').forEach((el) => {
      const on = el.dataset.fn === state.fn && el.dataset.stage === state.stage;
      el.classList.toggle('active', on);
    });
    const fnLayer = document.getElementById('fw-functions-layer');
    if (fnLayer) fnLayer.classList.toggle('active', state.mode === 'function' || state.mode === 'intersection');
  }

  function listHtml(title, items) {
    if (!items?.length) return '';
    return `<div class="fw-detail-block"><h4>${title}</h4><ul>${items.map((i) => `<li>${i}</li>`).join('')}</ul></div>`;
  }

  function renderDetail() {
    const kicker = document.getElementById('fw-detail-kicker');
    const title = document.getElementById('fw-detail-title');
    const content = document.getElementById('fw-detail-content');

    if (state.mode === 'structure') {
      kicker.textContent = ui.kickerStructure;
      title.textContent = state.structureTitle;
      content.innerHTML = `<p class="fw-detail-body">${state.structureBody}</p>`;
      return;
    }

    if (state.mode === 'intersection' && state.fn && state.stage) {
      const fn = fnMap[state.fn];
      const stage = stageMap[state.stage];
      const cell = intersections[state.fn]?.[state.stage];
      if (!fn || !stage || !cell) return;
      kicker.textContent = `${ui.kickerIntersection} · ${fn.label} × ${stage.title}`;
      title.textContent = cell.headline;
      content.innerHTML =
        listHtml(ui.howWorkRuns, cell.operations) +
        listHtml(ui.metricsToWatch, cell.metrics);
      return;
    }

    if (state.mode === 'function' && state.fn) {
      const fn = fnMap[state.fn];
      if (!fn) return;
      kicker.textContent = `${ui.kickerFunction} · ${fn.label}`;
      title.textContent = fn.purpose;
      content.innerHTML =
        `<p class="fw-detail-purpose"><strong>${ui.purposeLabel}</strong> ${fn.purpose}</p>` +
        listHtml(ui.coreActivities, fn.activities) +
        listHtml(ui.keyMetrics, fn.metrics);
      return;
    }

    if (state.mode === 'stage' && state.stage) {
      const stage = stageMap[state.stage];
      if (!stage) return;
      kicker.textContent = `${ui.kickerEvolution} · ${ui.kickerStage} ${stage.num}`;
      title.textContent = stage.title;
      content.innerHTML =
        `<p class="fw-detail-body">${stage.capabilityLocation}</p>` +
        listHtml(ui.howWorkPerformed, [stage.howWorkPerformed]) +
        listHtml(ui.whatChanges, [stage.operationalChange]);
    }
  }

  function showIntersection(fnId, stageId) {
    state.fn = fnId;
    state.stage = stageId;
    state.mode = 'intersection';
    setActive('cell', null, fnId, stageId);
    renderDetail();
  }

  function showFunction(fnId) {
    state.fn = fnId;
    state.mode = 'function';
    setActive('function', fnId, fnId, state.stage);
    renderDetail();
  }

  function showStage(stageId) {
    state.stage = stageId;
    state.mode = 'stage';
    setActive('stage', stageId, state.fn, stageId);
    renderDetail();
  }

  function showStructure(el) {
    state.mode = 'structure';
    state.structureTitle = el.dataset.title || '';
    state.structureBody = el.dataset.body || '';
    document.querySelectorAll('[data-kind="structure"]').forEach((node) => {
      node.classList.toggle('active', node === el);
    });
    document.querySelectorAll('[data-kind="function"], [data-kind="stage"], [data-kind="cell"]').forEach((node) => {
      node.classList.remove('active');
    });
    renderDetail();
  }

  function bindHover(el, fn) {
    el.addEventListener('mouseenter', () => fn(el));
    el.addEventListener('focus', () => fn(el));
    el.addEventListener('click', () => fn(el));
  }

  document.querySelectorAll('.fw-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab;
      document.querySelectorAll('.fw-tab').forEach((t) => {
        const on = t.dataset.tab === id;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      document.getElementById('fw-panel-structure').classList.toggle('active', id === 'structure');
      document.getElementById('fw-panel-structure').hidden = id !== 'structure';
      document.getElementById('fw-panel-evolution').classList.toggle('active', id === 'evolution');
      document.getElementById('fw-panel-evolution').hidden = id !== 'evolution';
    });
  });

  document.querySelectorAll('[data-kind="function"]').forEach((el) => bindHover(el, () => showFunction(el.dataset.id)));
  document.querySelectorAll('[data-kind="stage"]').forEach((el) => bindHover(el, () => showStage(el.dataset.id)));
  document.querySelectorAll('[data-kind="cell"]').forEach((el) =>
    bindHover(el, () => showIntersection(el.dataset.fn, el.dataset.stage))
  );
  document.querySelectorAll('[data-kind="structure"]').forEach((el) => bindHover(el, showStructure));

  showIntersection('sales', 'human');
</script>
