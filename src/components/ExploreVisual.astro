---
interface Props {
  topic: 'ai-maturity' | 'digital-workers' | 'agentic-workflows' | 'organizational-design' | 'enterprise-lessons';
}
const { topic } = Astro.props;
---
<div class="explore-visual" aria-hidden="true">
  {topic === 'ai-maturity' && (
    <svg viewBox="0 0 240 140" fill="none">
      <rect x="16" y="100" width="32" height="28" rx="4" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.5" />
      <rect x="56" y="78" width="32" height="50" rx="4" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="96" y="52" width="32" height="76" rx="4" fill="var(--card)" stroke="var(--accent-soft)" stroke-width="0.5" />
      <rect x="136" y="30" width="32" height="98" rx="4" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="176" y="14" width="32" height="114" rx="4" fill="var(--accent)" opacity="0.85" />
      <path d="M32 88 L72 66 L112 44 L152 28 L192 14" stroke="var(--accent)" stroke-width="2" stroke-dasharray="6 4" />
      <circle cx="192" cy="14" r="5" fill="var(--accent)" />
    </svg>
  )}
  {topic === 'digital-workers' && (
    <svg viewBox="0 0 240 140" fill="none">
      <rect x="20" y="24" width="72" height="92" rx="10" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <circle cx="56" cy="52" r="16" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <rect x="36" y="76" width="40" height="6" rx="2" fill="var(--line)" />
      <rect x="36" y="88" width="28" height="4" rx="1" fill="var(--line)" />
      <rect x="108" y="40" width="112" height="20" rx="6" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.5" />
      <rect x="108" y="68" width="112" height="20" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="108" y="96" width="112" height="20" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <path d="M92 52 H108 M92 78 H108 M92 106 H108" stroke="var(--accent-soft)" stroke-width="1.5" />
      <circle cx="200" cy="50" r="6" fill="var(--good)" opacity="0.4" />
    </svg>
  )}
  {topic === 'agentic-workflows' && (
    <svg viewBox="0 0 240 140" fill="none">
      <circle cx="48" cy="70" r="20" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1.5" />
      <circle cx="120" cy="40" r="16" fill="var(--card)" stroke="var(--accent-soft)" stroke-width="1" />
      <circle cx="120" cy="100" r="16" fill="var(--card)" stroke="var(--accent-soft)" stroke-width="1" />
      <circle cx="192" cy="70" r="20" fill="var(--accent)" opacity="0.2" stroke="var(--accent)" stroke-width="1.5" />
      <path d="M64 62 L104 46 M64 78 L104 94 M136 46 L172 62 M136 94 L172 78" stroke="var(--accent-soft)" stroke-width="1.5" />
      <rect x="108" y="62" width="24" height="16" rx="4" fill="var(--paper-2)" stroke="var(--line)" stroke-width="0.5" />
      <circle cx="48" cy="70" r="5" fill="var(--accent)" />
      <circle cx="192" cy="70" r="5" fill="var(--accent)" />
    </svg>
  )}
  {topic === 'organizational-design' && (
    <svg viewBox="0 0 240 140" fill="none">
      <rect x="88" y="16" width="64" height="36" rx="6" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <rect x="24" y="68" width="56" height="32" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="92" y="68" width="56" height="32" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="160" y="68" width="56" height="32" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="56" y="108" width="56" height="24" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="128" y="108" width="56" height="24" rx="6" fill="var(--good)" opacity="0.2" stroke="var(--good)" stroke-width="0.5" />
      <line x1="120" y1="52" x2="52" y2="68" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="120" y1="52" x2="120" y2="68" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="120" y1="52" x2="188" y2="68" stroke="var(--accent-soft)" stroke-width="1" />
      <line x1="52" y1="100" x2="84" y2="108" stroke="var(--line)" stroke-width="1" />
      <line x1="188" y1="100" x2="156" y2="108" stroke="var(--line)" stroke-width="1" />
    </svg>
  )}
  {topic === 'enterprise-lessons' && (
    <svg viewBox="0 0 240 140" fill="none">
      <rect x="24" y="48" width="88" height="72" rx="8" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <rect x="36" y="60" width="64" height="8" rx="2" fill="var(--line)" />
      <rect x="36" y="76" width="48" height="6" rx="2" fill="var(--line)" />
      <rect x="36" y="90" width="56" height="6" rx="2" fill="var(--line)" />
      <rect x="36" y="104" width="40" height="6" rx="2" fill="var(--accent-bg)" />
      <path d="M112 84 H148" stroke="var(--accent)" stroke-width="2" marker-end="url(#ex-arrow)" />
      <rect x="152" y="36" width="64" height="96" rx="8" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="1" />
      <rect x="164" y="50" width="40" height="6" rx="2" fill="var(--accent)" opacity="0.5" />
      <rect x="164" y="64" width="32" height="5" rx="1" fill="var(--line)" />
      <rect x="164" y="76" width="36" height="5" rx="1" fill="var(--line)" />
      <circle cx="184" cy="100" r="14" fill="var(--accent)" opacity="0.3" />
    </svg>
  )}
  <defs>
    <marker id="ex-arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6" fill="var(--accent)" />
    </marker>
  </defs>
</div>
