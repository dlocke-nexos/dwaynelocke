---
// Abstract editorial visual: People → Software → Automation → AI Agents
---
<div class="pub-evolution" aria-hidden="true">
  <svg viewBox="0 0 420 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="24" y1="60" x2="396" y2="60" stroke="var(--line)" stroke-width="1" />

    <!-- People -->
    <circle cx="48" cy="60" r="22" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
    <circle cx="40" cy="54" r="4" fill="var(--ink-soft)" />
    <circle cx="56" cy="54" r="4" fill="var(--ink-soft)" />
    <path d="M34 72 Q48 64 62 72" stroke="var(--ink-soft)" stroke-width="1.5" fill="none" />
    <text x="48" y="102" text-anchor="middle" fill="var(--ink-faint)" font-family="var(--sans)" font-size="10" letter-spacing="0.08em">PEOPLE</text>

    <path d="M74 60 L98 60" stroke="var(--accent-soft)" stroke-width="1" marker-end="url(#arrow)" />

    <!-- Software -->
    <rect x="110" y="38" width="44" height="44" rx="4" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
    <line x1="118" y1="50" x2="146" y2="50" stroke="var(--line)" stroke-width="1" />
    <line x1="118" y1="58" x2="140" y2="58" stroke="var(--line)" stroke-width="1" />
    <line x1="118" y1="66" x2="146" y2="66" stroke="var(--line)" stroke-width="1" />
    <text x="132" y="102" text-anchor="middle" fill="var(--ink-faint)" font-family="var(--sans)" font-size="10" letter-spacing="0.08em">SOFTWARE</text>

    <path d="M158 60 L182 60" stroke="var(--accent-soft)" stroke-width="1" />

    <!-- Automation -->
    <rect x="194" y="38" width="44" height="44" rx="22" stroke="var(--ink-faint)" stroke-width="1" fill="var(--card)" />
    <circle cx="216" cy="60" r="10" stroke="var(--accent-soft)" stroke-width="1" fill="none" />
    <circle cx="216" cy="60" r="3" fill="var(--accent)" />
    <text x="216" y="102" text-anchor="middle" fill="var(--ink-faint)" font-family="var(--sans)" font-size="10" letter-spacing="0.08em">AUTOMATION</text>

    <path d="M242 60 L266 60" stroke="var(--accent-soft)" stroke-width="1" />

    <!-- AI Agents -->
    <circle cx="290" cy="52" r="8" stroke="var(--accent)" stroke-width="1" fill="var(--accent-bg)" />
    <circle cx="318" cy="48" r="8" stroke="var(--accent)" stroke-width="1" fill="var(--accent-bg)" />
    <circle cx="330" cy="68" r="8" stroke="var(--accent)" stroke-width="1" fill="var(--accent-bg)" />
    <line x1="296" y1="56" x2="312" y2="50" stroke="var(--accent-soft)" stroke-width="1" />
    <line x1="296" y1="62" x2="324" y2="66" stroke="var(--accent-soft)" stroke-width="1" />
    <line x1="324" y1="54" x2="324" y2="60" stroke="var(--accent-soft)" stroke-width="1" />
    <text x="310" y="102" text-anchor="middle" fill="var(--ink-faint)" font-family="var(--sans)" font-size="10" letter-spacing="0.08em">AI AGENTS</text>

    <defs>
      <marker id="arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6" fill="var(--accent-soft)" />
      </marker>
    </defs>
  </svg>
</div>
