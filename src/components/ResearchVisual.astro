---
interface Props {
  slug: string;
  draft?: boolean;
}
const { slug, draft = false } = Astro.props;
---
<div class={`research-visual${draft ? ' research-visual--draft' : ''}`} aria-hidden="true">
  {slug === 'watching-organizations-adopt-ai' && (
    <svg viewBox="0 0 320 160" fill="none" class="rv-svg">
      <rect width="320" height="160" fill="var(--accent-bg)" opacity="0.45" />
      <circle cx="70" cy="52" r="16" fill="var(--card)" stroke="var(--accent)" stroke-width="1.2" />
      <circle cx="130" cy="42" r="12" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <circle cx="190" cy="58" r="14" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <circle cx="250" cy="38" r="11" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <path d="M82 58 L118 46 M142 50 L176 56 M204 54 L239 42" stroke="var(--accent-soft)" stroke-width="1" />
      <path d="M30 110 L80 88 L130 96 L180 72 L230 80 L290 58" stroke="var(--accent)" stroke-width="2.5" fill="none" />
      <circle cx="290" cy="58" r="5" fill="var(--accent)" />
      <text x="24" y="138" fill="var(--ink-faint)" font-family="var(--sans)" font-size="9" letter-spacing="0.1em">15 YEARS · CLOUD → AI</text>
    </svg>
  )}

  {slug === 'digital-worker' && (
    <svg viewBox="0 0 320 160" fill="none" class="rv-svg">
      <rect width="320" height="160" fill="var(--paper-2)" />
      <!-- triggers into ears -->
      <text x="18" y="52" fill="var(--accent)" font-family="var(--sans)" font-size="8" font-weight="600">TRIGGERS</text>
      <path d="M8 58 H42" stroke="var(--accent)" stroke-width="1.5" marker-end="url(#rv-arr)" />
      <path d="M8 72 H42" stroke="var(--accent-soft)" stroke-width="1.5" marker-end="url(#rv-arr)" />
      <path d="M278 58 H242" stroke="var(--accent)" stroke-width="1.5" marker-end="url(#rv-arr-l)" />
      <path d="M278 72 H242" stroke="var(--accent-soft)" stroke-width="1.5" marker-end="url(#rv-arr-l)" />
      <!-- ears -->
      <rect x="42" y="48" width="14" height="32" rx="7" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <rect x="264" y="48" width="14" height="32" rx="7" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <!-- robot head/body -->
      <rect x="68" y="36" width="184" height="88" rx="18" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1.2" />
      <circle cx="120" cy="68" r="8" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <circle cx="200" cy="68" r="8" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <rect x="108" y="82" width="104" height="8" rx="4" fill="var(--line)" />
      <!-- brain + memory out -->
      <text x="108" y="22" fill="var(--ink-faint)" font-family="var(--sans)" font-size="8" font-weight="600">BRAIN</text>
      <path d="M160 36 V18" stroke="var(--accent-soft)" stroke-width="1.5" />
      <ellipse cx="160" cy="12" rx="22" ry="10" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1" />
      <text x="148" y="15" fill="var(--accent)" font-family="var(--sans)" font-size="7" font-weight="600">MEMORY</text>
      <!-- hands doing work -->
      <text x="118" y="152" fill="var(--ink-faint)" font-family="var(--sans)" font-size="8" font-weight="600">ACTION</text>
      <rect x="88" y="128" width="36" height="22" rx="6" fill="var(--good)" opacity="0.25" stroke="var(--good)" stroke-width="0.8" />
      <rect x="148" y="128" width="36" height="22" rx="6" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.8" />
      <rect x="208" y="128" width="36" height="22" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.8" />
      <path d="M124 124 V128 M166 124 V128 M226 124 V128" stroke="var(--accent-soft)" stroke-width="1.5" />
      <defs>
        <marker id="rv-arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6" fill="var(--accent)" /></marker>
        <marker id="rv-arr-l" markerWidth="6" markerHeight="6" refX="1" refY="3" orient="auto"><path d="M6,0 L0,3 L6,6" fill="var(--accent)" /></marker>
      </defs>
    </svg>
  )}

  {slug === 'understand-before-automate' && (
    <svg viewBox="0 0 320 160" fill="none" class="rv-svg">
      <rect width="320" height="160" fill="var(--accent-bg)" opacity="0.3" />
      <!-- swim lane bands -->
      <rect x="12" y="24" width="296" height="36" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="12" y="62" width="296" height="36" fill="var(--paper)" stroke="var(--line)" stroke-width="0.5" />
      <rect x="12" y="100" width="296" height="36" fill="var(--card)" stroke="var(--line)" stroke-width="0.5" />
      <text x="16" y="46" fill="var(--ink-faint)" font-family="var(--sans)" font-size="8" font-weight="600">OWNER</text>
      <text x="16" y="84" fill="var(--ink-faint)" font-family="var(--sans)" font-size="8" font-weight="600">TEAM</text>
      <text x="16" y="122" fill="var(--ink-faint)" font-family="var(--sans)" font-size="8" font-weight="600">SYSTEM</text>
      <!-- flow shapes -->
      <rect x="52" y="34" width="40" height="16" rx="4" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.8" />
      <path d="M92 42 H104" stroke="var(--accent)" stroke-width="1.2" />
      <polygon points="112,42 120,34 128,42 120,50" fill="var(--card)" stroke="var(--accent)" stroke-width="1" />
      <text x="116" y="45" fill="var(--accent)" font-family="var(--sans)" font-size="6" font-weight="700">?</text>
      <!-- yes branch -->
      <path d="M128 42 H160" stroke="var(--good)" stroke-width="1.2" />
      <text x="140" y="38" fill="var(--good)" font-family="var(--sans)" font-size="7" font-weight="600">Y</text>
      <rect x="160" y="72" width="44" height="16" rx="4" fill="var(--card)" stroke="var(--line)" stroke-width="0.8" />
      <!-- no branch -->
      <path d="M120 50 V68 H72 V76" stroke="var(--accent)" stroke-width="1" stroke-dasharray="3 2" />
      <text x="100" y="64" fill="var(--accent)" font-family="var(--sans)" font-size="7" font-weight="600">N</text>
      <rect x="52" y="72" width="40" height="16" rx="4" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="0.8" />
      <!-- system lane -->
      <rect x="220" y="108" width="52" height="16" rx="4" fill="var(--good)" opacity="0.3" stroke="var(--good)" stroke-width="0.8" />
      <path d="M204 80 H220 V116" stroke="var(--accent-soft)" stroke-width="1" />
      <path d="M96 42 H180 V80 H220" stroke="var(--accent-soft)" stroke-width="1" fill="none" />
    </svg>
  )}

  {slug === 'ai-deployment-model' && (
    <svg viewBox="0 0 320 160" fill="none" class="rv-svg">
      <rect width="320" height="160" fill="var(--paper-2)" />
      <text x="16" y="22" fill="var(--ink-faint)" font-family="var(--sans)" font-size="8" font-weight="600" letter-spacing="0.08em">SAAS</text>
      <rect x="16" y="28" width="288" height="28" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="0.8" />
      <text x="24" y="46" fill="var(--ink-soft)" font-family="var(--sans)" font-size="7">Select → Configure → Integrate → Test → Deploy → Maintain</text>
      <text x="16" y="78" fill="var(--accent)" font-family="var(--sans)" font-size="8" font-weight="600" letter-spacing="0.08em">AI</text>
      <rect x="16" y="84" width="288" height="36" rx="6" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="0.8" />
      <text x="24" y="100" fill="var(--ink)" font-family="var(--sans)" font-size="7" font-weight="600">Architect → Generate → Wire → Evaluate</text>
      <text x="24" y="112" fill="var(--ink-soft)" font-family="var(--sans)" font-size="7">→ Test → Deploy → Maintain</text>
      <rect x="16" y="130" width="52" height="18" rx="4" fill="var(--accent)" opacity="0.85" />
      <text x="22" y="142" fill="var(--paper)" font-family="var(--sans)" font-size="7" font-weight="600">GENERATE</text>
      <text x="76" y="142" fill="var(--ink-faint)" font-family="var(--sans)" font-size="7">capability created, not purchased</text>
    </svg>
  )}

  {slug === 'operational-memory' && (
    <svg viewBox="0 0 320 160" fill="none" class="rv-svg">
      <rect width="320" height="160" fill="var(--paper-2)" />
      <!-- workspace 1 -->
      <rect x="16" y="20" width="88" height="120" rx="8" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <text x="24" y="38" fill="var(--accent)" font-family="monospace" font-size="8" font-weight="600">CLAUDE.md</text>
      <line x1="24" y1="48" x2="96" y2="48" stroke="var(--line)" stroke-width="1" />
      <text x="24" y="62" fill="var(--ink-soft)" font-family="monospace" font-size="7">memory.md</text>
      <text x="24" y="76" fill="var(--ink-faint)" font-family="monospace" font-size="7">skills/</text>
      <text x="24" y="90" fill="var(--ink-faint)" font-family="monospace" font-size="7">agents/</text>
      <text x="24" y="104" fill="var(--ink-faint)" font-family="monospace" font-size="7">.cursor/</text>
      <!-- workspace 2 -->
      <rect x="116" y="20" width="88" height="120" rx="8" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="1" />
      <text x="124" y="38" fill="var(--accent)" font-family="monospace" font-size="8" font-weight="600">MEMORY.md</text>
      <line x1="124" y1="48" x2="196" y2="48" stroke="var(--accent-soft)" stroke-width="1" />
      <text x="124" y="62" fill="var(--ink-soft)" font-family="monospace" font-size="7">SOPs/</text>
      <text x="124" y="76" fill="var(--ink-soft)" font-family="monospace" font-size="7">prompts/</text>
      <text x="124" y="90" fill="var(--ink-faint)" font-family="monospace" font-size="7">decisions/</text>
      <text x="124" y="104" fill="var(--ink-faint)" font-family="monospace" font-size="7">workflows/</text>
      <!-- workspace 3 -->
      <rect x="216" y="20" width="88" height="120" rx="8" fill="var(--card)" stroke="var(--line)" stroke-width="1" />
      <text x="224" y="38" fill="var(--ink-soft)" font-family="monospace" font-size="8" font-weight="600">workspace/</text>
      <line x1="224" y1="48" x2="296" y2="48" stroke="var(--line)" stroke-width="1" />
      <text x="232" y="62" fill="var(--ink-faint)" font-family="monospace" font-size="7">rules/</text>
      <text x="232" y="76" fill="var(--ink-faint)" font-family="monospace" font-size="7">context/</text>
      <text x="232" y="90" fill="var(--ink-faint)" font-family="monospace" font-size="7">tools/</text>
      <text x="232" y="104" fill="var(--accent)" font-family="monospace" font-size="7">DNA</text>
      <!-- connect -->
      <path d="M104 80 H116 M204 80 H216" stroke="var(--accent-soft)" stroke-width="1.5" marker-end="url(#rv-mem-arr)" />
      <defs>
        <marker id="rv-mem-arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6" fill="var(--accent-soft)" /></marker>
      </defs>
    </svg>
  )}

  {slug === 'digital-twin' && (
    <svg viewBox="0 0 320 160" fill="none" class="rv-svg">
      <rect width="320" height="160" fill="var(--paper-2)" />
      <rect x="14" y="20" width="132" height="104" rx="8" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <text x="22" y="36" fill="var(--accent)" font-family="var(--sans)" font-size="8" font-weight="600">YOU</text>
      <path d="M80 76 L52 98 M80 76 L80 98 M80 76 L108 98" stroke="var(--accent-soft)" stroke-width="1" />
      <circle cx="80" cy="64" r="12" fill="var(--accent-bg)" stroke="var(--accent)" stroke-width="1.2" />
      <circle cx="52" cy="104" r="8" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <circle cx="80" cy="104" r="8" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <circle cx="108" cy="104" r="8" fill="var(--card)" stroke="var(--ink-faint)" stroke-width="1" />
      <path d="M150 64 H172" stroke="var(--accent-soft)" stroke-width="1.4" stroke-dasharray="2 3" marker-end="url(#rv-twin-arr)" />
      <rect x="174" y="20" width="132" height="104" rx="8" fill="var(--accent-bg)" stroke="var(--accent-soft)" stroke-width="1" />
      <text x="182" y="36" fill="var(--accent)" font-family="var(--sans)" font-size="8" font-weight="600">DIGITAL TWIN</text>
      <path d="M240 76 L212 98 M240 76 L240 98 M240 76 L268 98" stroke="var(--accent)" stroke-width="1" />
      <circle cx="240" cy="64" r="12" fill="var(--accent)" />
      <circle cx="212" cy="104" r="8" fill="var(--card)" stroke="var(--accent)" stroke-width="1.2" />
      <circle cx="240" cy="104" r="8" fill="var(--card)" stroke="var(--accent)" stroke-width="1.2" />
      <circle cx="268" cy="104" r="8" fill="var(--card)" stroke="var(--accent)" stroke-width="1.2" />
      <text x="22" y="146" fill="var(--ink-faint)" font-family="var(--sans)" font-size="7" letter-spacing="0.06em">capture · configure · operate · maintain</text>
      <defs>
        <marker id="rv-twin-arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6" fill="var(--accent-soft)" /></marker>
      </defs>
    </svg>
  )}

  {/* fallback for unknown slugs */}
  {slug !== 'watching-organizations-adopt-ai' && slug !== 'digital-worker' && slug !== 'understand-before-automate' && slug !== 'operational-memory' && slug !== 'ai-deployment-model' && slug !== 'digital-twin' && (
    <svg viewBox="0 0 320 160" fill="none" class="rv-svg">
      <rect width="320" height="160" fill="var(--paper-2)" />
      <rect x="110" y="50" width="100" height="60" rx="6" fill="var(--card)" stroke="var(--line)" stroke-width="1" />
      <line x1="124" y1="70" x2="196" y2="70" stroke="var(--accent)" stroke-width="1.5" />
      <line x1="124" y1="84" x2="170" y2="84" stroke="var(--line)" stroke-width="1" />
    </svg>
  )}
</div>
