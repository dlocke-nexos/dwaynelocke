---
// Newsletter signup. The submit handler `subscribe()` is a PLACEHOLDER
// defined in Assessment.astro — see the TODO(email) there to wire your provider.
---
<section class="news" id="newsletter">
  <div class="inner">
    <h2>Follow the exploration</h2>
    <p>One essay at a time, as I work through what changes when organizations start adopting AI. No noise, no pitch — just the notes as they come.</p>
    <form onsubmit="return subscribe(event)">
      <input type="email" id="email" placeholder="you@company.com" required />
      <button type="submit">Subscribe</button>
    </form>
    <div class="fine" id="newsfine">Roughly weekly. Unsubscribe anytime.</div>
  </div>
</section>
