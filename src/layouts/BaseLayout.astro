---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Assessment from '../components/Assessment.astro';

interface Props {
  title: string;
  description?: string;
  /** Path back to the homepage for nav anchors ('/' on home, '/' on essays too). */
  home?: string;
}
const {
  title,
  description = "Notes on how organizations evolve — working through what changes when technology stops documenting work and starts performing it.",
  home = '/',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,400i;9..144,500i&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <Nav home={home} />
  <slot />
  <Footer home={home} />
  <Assessment />
</body>
</html>
