---
import '../styles/global.css';
import HomeNav from '../components/HomeNav.astro';
import HomeFooter from '../components/HomeFooter.astro';
import Assessment from '../components/Assessment.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'How organizations scale in the age of AI — a publication exploring dependency, process, and the operating models that come next.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,400i;9..144,500i&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <HomeNav />
  <slot />
  <HomeFooter />
  <Assessment />
</body>
</html>
